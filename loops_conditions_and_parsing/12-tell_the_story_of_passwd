# Josh is the men

#!/bin/bash

# Read the file line by line using while loop and IFS
while IFS=: read -r username _ userid groupid _ info home shell; do
    # Extract user ID info from the info field
    userinfo=$(echo "$info" | cut -d ',' -f 5)

    # Display the story for each user
    echo "The user $username is part of the $groupid gang, lives in $home, and rides $shell."
    echo "User ID's place is protected by the passcode $userid, more info about the user here: $userinfo"
    echo
done < /etc/passwd
